---
import { getPublishedWarehouses, getWarehouseUrl } from '../lib/warehouses';
import { relativePath } from '../lib/paths';

const currentPath = Astro.url.pathname;
const warehouses = await getPublishedWarehouses();
const yandexApiKey = import.meta.env.PUBLIC_YANDEX_MAPS_API_KEY ?? '';

const centerLat = 41.311081;
const centerLng = 69.240562;
---

<section id="top" class="hero-showcase" aria-label="Аренда складов от собственника в Ташкенте">
  <div class="hero-title-panel">
    <div class="hero-title-content">
      <p class="eyebrow">ArendaSklada.uz · напрямую от собственника</p>
      <h1>Складские объекты в аренду в Ташкенте</h1>
      <p class="lead">
        Подберите склад по площади, температурному режиму, готовности и формату аренды.
        Объекты отмечены на карте, а заявка отправляется напрямую владельцу.
      </p>

      <div class="hero-actions">
        <a class="button button-light" href="#warehouses">Подобрать объект</a>
        <a class="button button-ghost" href="#contacts">Оставить заявку</a>
      </div>
    </div>
  </div>

  <div id="location" class="hero-showcase-map-wrap">
    <div
      class="hero-yandex-map hero-showcase-map"
      data-yandex-map
      data-yandex-api-key={yandexApiKey}
      data-center-lat={centerLat}
      data-center-lng={centerLng}
      data-zoom="11"
      aria-label="Яндекс карта складских объектов в Ташкенте"
    >
      <div class="hero-map-fallback" aria-hidden="true">
        <span class="hero-map-road hero-map-road-a"></span>
        <span class="hero-map-road hero-map-road-b"></span>
        <span class="hero-map-road hero-map-road-c"></span>
        <span class="hero-map-label">Ташкент</span>

        {warehouses.map((warehouse, index) => {
          const data = warehouse.data;
          const href = relativePath(getWarehouseUrl(warehouse), currentPath);
          const search = `${data.title} ${data.block} ${data.city} ${data.district} ${data.propertyType} ${data.area} ${data.temperatureMode} ${data.leaseType} ${data.ready}`;

          return (
            <a
              class="hero-yandex-point"
              href={href}
              title={`${data.title}, ${data.district}, ${data.area} м²`}
              style={`left: ${data.mapX}%; top: ${data.mapY}%;`}
              data-property-marker
              data-yandex-point
              data-title={data.title}
              data-city={data.city}
              data-district={data.district}
              data-type={data.propertyType}
              data-area={data.area}
              data-availability={data.ready}
              data-temperature={data.temperatureMode}
              data-lease-type={data.leaseType}
              data-order={data.order}
              data-lat={data.latitude}
              data-lng={data.longitude}
              data-url={href}
              data-search={search}
              aria-label={`${data.title}, ${data.district}, ${data.area} м²`}
            >
              <span class="hero-point-number">{index + 1}</span>
              <span class="hero-point-card" aria-hidden="true">
                <strong>{data.title}</strong>
                <small>{data.district}</small>
                <b>{data.area.toLocaleString('ru-RU')} м² · {data.warehouseClass}</b>
                <em>{data.temperatureMode} · {data.leaseType}</em>
              </span>
            </a>
          );
        })}
      </div>
    </div>
  </div>
</section>
