---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import { absoluteUrl, homeAnchor, relativePath } from '../lib/paths';

export async function getStaticPaths() {
  const warehouses = await getCollection('warehouses', ({ data }) => data.published !== false);

  return warehouses.map((warehouse) => ({
    params: { slug: warehouse.data.pageSlug },
    props: { warehouse },
  }));
}

const { warehouse } = Astro.props as { warehouse: CollectionEntry<'warehouses'> };
const data = warehouse.data;

const currentPath = Astro.url.pathname;
const canonical = absoluteUrl(`/${data.pageSlug}/`);
const mainImage = relativePath(data.mainImage, currentPath);
const gallery = data.gallery.map((image) => relativePath(image, currentPath));
const planImage = relativePath(data.planImage, currentPath);
const photos = [mainImage, ...gallery]
  .filter((value, index, values) => value && values.indexOf(value) === index)
  .slice(0, 2);

while (photos.length < 2) photos.push(mainImage);

const displayTitle = data.title.replace(/^Логистический центр\s*[—-]\s*/i, '');
const rawPrice = String(data.price ?? '').trim();
const priceNumber = rawPrice.match(/\d+(?:[.,]\d+)?/)?.[0];
const rentRate = rawPrice.toLowerCase() === 'по запросу' || !priceNumber
  ? 'По запросу'
  : `от $ ${priceNumber} за м²`;

const primaryFacts = [
  ['Площадь', `${data.area.toLocaleString('ru-RU')} м²`],
  ['Ставка аренды', rentRate],
  ['Район / локация', data.district],
  ['Высота потолков', data.ceilingHeight],
  ['Температурный режим', data.temperatureMode],
  ['Тип аренды', data.leaseType],
  ['Готовность', data.ready],
  ['Год постройки', data.builtYear ? String(data.builtYear) : 'По запросу'],
];

const generalFacts = [
  ['Тип объекта', data.propertyType],
  ['Класс склада', data.warehouseClass],
  ['Этаж', data.floor],
  ['Формат хранения', data.warehouseLayout],
  ['Доковые ворота', data.dockDoors],
  ['Рабочие места', data.workplaces],
  ['Адрес', data.address],
  ['Блок / корпус', data.block],
].filter(([, value]) => String(value ?? '').trim());

const mapHref = `https://yandex.ru/maps/?pt=${data.longitude},${data.latitude}&z=14&l=map`;
const mapWidgetSrc = `https://yandex.ru/map-widget/v1/?ll=${data.longitude}%2C${data.latitude}&z=14&pt=${data.longitude}%2C${data.latitude},pm2rdm`;
---

<BaseLayout
  title={data.seoTitle}
  description={data.description}
  canonical={canonical}
  image={absoluteUrl(data.mainImage)}
>
  <Header />

  <main class="warehouse-detail-main warehouse-object-page">
    <section class="warehouse-object-section">
      <div class="container warehouse-object-container">
        <article class="warehouse-dossier">
          <header class="warehouse-dossier-header">
            <div class="warehouse-dossier-heading">
              <p class="eyebrow">Карточка складского объекта</p>
              <h1>{displayTitle}</h1>
            </div>

            <div class="warehouse-dossier-badges" aria-label="Ключевые статусы объекта">
              <span>{data.ready}</span>
              <strong>{data.warehouseClass ? `Класс ${data.warehouseClass}` : data.propertyType}</strong>
            </div>
          </header>

          <div class="warehouse-dossier-body">
            <section class="warehouse-dossier-info" aria-label="Характеристики объекта">
              <dl class="warehouse-dossier-primary">
                {primaryFacts.map(([label, value]) => (
                  <div>
                    <dt>{label}:</dt>
                    <dd>{value}</dd>
                  </div>
                ))}
              </dl>

              <section class="warehouse-dossier-general">
                <div class="warehouse-dossier-section-title">
                  <span>Общая информация</span>
                  <strong>Характеристики объекта</strong>
                </div>

                <dl class="warehouse-dossier-general-grid">
                  {generalFacts.map(([label, value]) => (
                    <div>
                      <dt>{label}</dt>
                      <dd>{value}</dd>
                    </div>
                  ))}
                </dl>

                <div class="warehouse-dossier-description">
                  <p>{data.intro}</p>

                  {data.detailFeatures.length > 0 && (
                    <ul aria-label="Дополнительные особенности">
                      {data.detailFeatures.map((feature) => <li>{feature}</li>)}
                    </ul>
                  )}
                </div>
              </section>

              <div class="warehouse-dossier-actions">
                <a class="button button-dark" href={homeAnchor('contacts', currentPath)}>Получить предложение</a>
                <a class="button" href={homeAnchor('warehouses', currentPath)}>Все склады</a>
              </div>
            </section>

            <aside class="warehouse-dossier-map">
              <div class="warehouse-dossier-map-head">
                <div>
                  <span>Расположение объекта</span>
                  <strong>{data.district}</strong>
                </div>
                <a href={mapHref} target="_blank" rel="noopener noreferrer">Открыть карту</a>
              </div>

              <iframe
                src={mapWidgetSrc}
                title={`Карта объекта ${displayTitle}`}
                loading="eager"
                allowfullscreen
              ></iframe>
            </aside>
          </div>

          <section class="warehouse-dossier-media" aria-label="Фотографии и планировка объекта">
            {photos.map((image, index) => (
              <article class="warehouse-dossier-media-card">
                <button
                  class="image-open-button"
                  type="button"
                  data-lightbox-src={image}
                  data-lightbox-alt={`${index === 0 ? 'Главное фото' : 'Дополнительное фото'} объекта ${displayTitle}`}
                  aria-label={`Открыть ${index === 0 ? 'главное фото' : 'дополнительное фото'} объекта`}
                >
                  <img src={image} alt={`${data.imageAlt}, фото ${index + 1}`} />
                </button>
                <span>{index === 0 ? 'Главное фото' : 'Дополнительное фото'}</span>
              </article>
            ))}

            <article class="warehouse-dossier-media-card warehouse-dossier-media-card--plan">
              <button
                class="image-open-button"
                type="button"
                data-lightbox-src={planImage}
                data-lightbox-alt={`Планировка объекта ${displayTitle}`}
                aria-label="Открыть планировку объекта"
              >
                <img src={planImage} alt={`Планировка объекта ${displayTitle}`} />
              </button>
              <span>Планировка</span>
            </article>
          </section>
        </article>
      </div>
    </section>
  </main>
</BaseLayout>
