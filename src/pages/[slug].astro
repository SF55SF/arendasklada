---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import { absoluteUrl, homeAnchor, relativePath } from '../lib/paths';

export async function getStaticPaths() {
  const warehouses = await getCollection('warehouses', ({ data }) => data.published !== false);
  return warehouses.map((warehouse) => ({
    params: { slug: warehouse.data.pageSlug },
    props: { warehouse },
  }));
}

const { warehouse } = Astro.props as { warehouse: CollectionEntry<'warehouses'> };
const data = warehouse.data;
const currentPath = Astro.url.pathname;
const canonical = absoluteUrl(`/${data.pageSlug}/`);
const title = data.title.replace(/^Логистический центр\s*[—-]\s*/i, '');
const mainImage = relativePath(data.mainImage, currentPath);
const gallery = (data.gallery ?? []).map((image) => relativePath(image, currentPath));
const planImage = data.planImage ? relativePath(data.planImage, currentPath) : '';
const rawPrice = String(data.price ?? '').trim();
const priceNumber = rawPrice.match(/\d+(?:[.,]\d+)?/)?.[0];
const rentRate = rawPrice.toLowerCase() === 'по запросу' || !priceNumber
  ? 'По запросу'
  : `от $ ${priceNumber} за м²`;

const summary = [
  ['Регион', data.district],
  ['Площадь', `${data.area.toLocaleString('ru-RU')} м²`],
  ['Ставка аренды', rentRate],
  ['Готовность', data.ready],
];

const specs = [
  ['Класс склада', data.warehouseClass],
  ['Высота потолков', data.ceilingHeight],
  ['Температурный режим', data.temperatureMode],
  ['Тип аренды', data.leaseType],
  ['Доковые ворота', data.dockDoors],
  ['Этаж', data.floor],
  ['Год постройки', data.builtYear ? String(data.builtYear) : 'По запросу'],
  ['Адрес', data.address],
].filter(([, value]) => String(value ?? '').trim());

const mapHref = `https://yandex.ru/maps/?pt=${data.longitude},${data.latitude}&z=14&l=map`;
const mapSrc = `https://yandex.ru/map-widget/v1/?ll=${data.longitude}%2C${data.latitude}&z=14&pt=${data.longitude}%2C${data.latitude},pm2rdm`;
const photos = gallery.filter((image) => image && image !== mainImage).slice(0, 2);
---

<BaseLayout title={data.seoTitle} description={data.description} canonical={canonical} image={absoluteUrl(data.mainImage)}>
  <Header />

  <main class="ir-page">
    <section class="ir-hero">
      <div class="ir-wrap">
        <nav class="ir-crumbs">
          <a href={homeAnchor('warehouses', currentPath)}>Склады в аренду</a>
          <span>/</span>
          <span>{title}</span>
        </nav>

        <div class="ir-title">
          <div>
            <p>Складской объект</p>
            <h1>{title}</h1>
            <span>{data.district}, {data.city}</span>
          </div>
          <a href={homeAnchor('warehouses', currentPath)}>Все склады</a>
        </div>

        <div class="ir-lead">
          <button class="ir-main image-open-button" type="button" data-lightbox-src={mainImage} data-lightbox-alt={`Главное фото объекта ${title}`}>
            <img src={mainImage} alt={data.imageAlt} />
          </button>

          <aside class="ir-summary">
            <dl>
              {summary.map(([label, value]) => (
                <div><dt>{label}</dt><dd>{value}</dd></div>
              ))}
            </dl>
            <a class="ir-cta" href={homeAnchor('contacts', currentPath)}>Получить предложение</a>
            <!-- DETAIL_TELEGRAM_CONTACT_START -->
            <a class="ir-summary-contact" href="https://t.me/sanjar_saymatov_cmwp" target="_blank" rel="noopener noreferrer" aria-label="Связаться в Telegram">
              <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                <path d="M6.7 3.8c.4-.4 1-.5 1.5-.2l2.1 1.2c.5.3.7.9.5 1.4l-.9 2c-.2.5-.1 1 .2 1.4l1.8 1.9 1.9 1.8c.4.3.9.4 1.4.2l2-.9c.5-.2 1.1 0 1.4.5l1.2 2.1c.3.5.2 1.1-.2 1.5l-1 1c-.8.8-2 1.1-3.1.8-2.6-.7-5.1-2.2-7.4-4.5S4.3 9.2 3.6 6.6c-.3-1.1 0-2.3.8-3.1l1-1Z" />
              </svg>
            </a>
            <!-- DETAIL_TELEGRAM_CONTACT_END -->
          </aside>
        </div>
      </div>
    </section>

    <section class="ir-body">
      <div class="ir-wrap">
        <div class="ir-copy">
          <article>
            <p class="ir-kicker">Об объекте</p>
            <h2>Современный складской комплекс</h2>
            <p>{data.intro}</p>
            {(data.detailFeatures ?? []).length > 0 && (
              <ul>{(data.detailFeatures ?? []).map((feature) => <li>{feature}</li>)}</ul>
            )}
          </article>
          <article>
            <p class="ir-kicker">Локация</p>
            <h2>{data.district}</h2>
            <p>{data.address}</p>
            <p>Удобное расположение для городской и региональной логистики.</p>
          </article>
        </div>

        <div class="ir-grid">
          <section class="ir-specs">
            <p class="ir-kicker">Параметры</p>
            <h2>Технические характеристики</h2>
            <dl>
              {specs.map(([label, value]) => (
                <div><dt>{label}</dt><dd>{value}</dd></div>
              ))}
            </dl>
          </section>

          <aside class="ir-map">
            <div><p class="ir-kicker">Карта</p><h2>Расположение объекта</h2><a href={mapHref} target="_blank" rel="noopener noreferrer">Открыть карту</a></div>
            <div class="ir-map-frame" data-detail-ctrl-map>
              <iframe src={mapSrc} title={`Карта объекта ${title}`} loading="lazy" allowfullscreen></iframe>
              <div class="detail-map-wheel-shield" aria-hidden="true"></div>
              <div class="detail-map-ctrl-hint" aria-hidden="true"><kbd>Ctrl</kbd><span class="detail-map-ctrl-hint__plus">+</span><span class="detail-map-ctrl-hint__wheel">колесо</span><span class="detail-map-ctrl-hint__text">Удерживайте левый Ctrl и прокручивайте колесо</span></div>
            </div>
          </aside>
        </div>

        {(photos.length > 0 || planImage) && (
          <section class="ir-gallery">
            <p class="ir-kicker">Галерея</p>
            <h2>Фотографии и планировка</h2>
            <div>
              {photos.map((image, index) => (
                <button class="image-open-button" type="button" data-lightbox-src={image} data-lightbox-alt={`Фото ${index + 2} объекта ${title}`}>
                  <img src={image} alt={`${data.imageAlt}, фото ${index + 2}`} />
                </button>
              ))}
              {planImage && (
                <button class="image-open-button ir-plan" type="button" data-lightbox-src={planImage} data-lightbox-alt={`Планировка объекта ${title}`}>
                  <img src={planImage} alt={`Планировка объекта ${title}`} />
                </button>
              )}
            </div>
          </section>
        )}
      </div>
    </section>
  </main>

  <style is:global>
    html:has(.ir-page),body:has(.ir-page){margin:0;background:#ededed;color:#222}
    .ir-page,.ir-page *{box-sizing:border-box;font-family:Roboto,Arial,sans-serif}
    .ir-wrap{width:min(1440px,calc(100% - 48px));margin:auto}
    .ir-hero{padding:32px 0 52px;background:#f3f3f3;border-bottom:1px solid #d5d5d5}
    .ir-crumbs{display:flex;gap:8px;margin-bottom:25px;color:#777;font-size:13px}
    .ir-crumbs a{color:#444;text-decoration:none}
    .ir-title{display:flex;justify-content:space-between;align-items:flex-end;gap:24px;margin-bottom:26px}
    .ir-title p,.ir-kicker{margin:0 0 8px;color:#777;font-size:12px;font-weight:700;letter-spacing:.12em;text-transform:uppercase}
    .ir-title h1{margin:0;max-width:980px;font-size:clamp(44px,5vw,76px);font-weight:800;line-height:.96;letter-spacing:-.045em}
    .ir-title div>span{display:block;margin-top:13px;color:#666;font-size:18px}
    .ir-title>a,.ir-map a{padding:11px 15px;border:1px solid #aaa;color:#292929;font-size:13px;font-weight:700;text-decoration:none}
    .ir-lead{display:grid;grid-template-columns:minmax(0,1.7fr) minmax(330px,.6fr);min-height:560px;background:#d2d2d2}
    .ir-main{display:block;width:100%;min-height:560px;padding:0;border:0;background:#ccc;overflow:hidden;cursor:zoom-in}
    .ir-main img{display:block;width:100%;height:100%;min-height:560px;object-fit:cover}
    .ir-summary{display:flex;flex-direction:column;padding:36px 32px;background:#303030;color:#fff}
    .ir-summary dl{margin:0}
    .ir-summary dl>div{padding:22px 0;border-bottom:1px solid #505050}
    .ir-summary dt{margin:0 0 7px;color:#aaa;font-size:12px;font-weight:700;text-transform:uppercase}
    .ir-summary dd{margin:0;font-size:22px;font-weight:700;line-height:1.2;overflow-wrap:anywhere}
    .ir-cta{display:flex;align-items:center;justify-content:center;min-height:54px;margin-top:auto;background:#eee;color:#222;font-size:14px;font-weight:800;text-decoration:none;text-transform:uppercase}
    .ir-body{padding:68px 0 90px;background:#ededed}
    .ir-copy{display:grid;grid-template-columns:minmax(0,1.35fr) minmax(300px,.65fr);gap:60px;padding-bottom:58px;border-bottom:1px solid #ccc}
    .ir-copy h2,.ir-specs h2,.ir-map h2,.ir-gallery h2{margin:0 0 18px;font-size:clamp(27px,2.3vw,38px);line-height:1.08;letter-spacing:-.025em}
    .ir-copy p:not(.ir-kicker){margin:0 0 15px;color:#555;font-size:17px;line-height:1.65}
    .ir-copy ul{display:flex;flex-wrap:wrap;gap:8px;margin:22px 0 0;padding:0;list-style:none}
    .ir-copy li{padding:8px 10px;border:1px solid #c8c8c8;background:#f6f6f6;color:#444;font-size:13px;font-weight:600}
    .ir-grid{display:grid;grid-template-columns:minmax(0,1.18fr) minmax(350px,.82fr);gap:30px;padding-top:58px}
    .ir-specs,.ir-map,.ir-gallery{background:#f7f7f7;border:1px solid #d0d0d0}
    .ir-specs{padding:32px}
    .ir-specs dl{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));margin:26px 0 0;border-top:1px solid #ccc}
    .ir-specs dl>div{display:grid;grid-template-columns:minmax(120px,.8fr) minmax(0,1.2fr);gap:16px;padding:16px 0;border-bottom:1px solid #d4d4d4}
    .ir-specs dl>div:nth-child(odd){padding-right:24px}
    .ir-specs dl>div:nth-child(even){padding-left:24px;border-left:1px solid #d4d4d4}
    .ir-specs dt,.ir-specs dd{margin:0;font-size:16.8px;line-height:1.4}
    .ir-specs dt{color:#777;font-weight:600}
    .ir-specs dd{font-weight:700;overflow-wrap:anywhere}
    .ir-map{display:grid;grid-template-rows:auto 1fr;min-height:590px;overflow:hidden}
    .ir-map>div{position:relative;padding:28px;background:#dedede}
    .ir-map h2{margin-bottom:0}
    .ir-map a{position:absolute;right:28px;bottom:28px}
    .ir-map iframe{width:100%;height:100%;min-height:460px;border:0}
    .ir-gallery{margin-top:30px;padding:32px}
    .ir-gallery>div{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:14px}
    .ir-gallery button{display:block;width:100%;min-height:280px;padding:0;border:0;background:#d3d3d3;overflow:hidden;cursor:zoom-in}
    .ir-gallery img{display:block;width:100%;height:100%;min-height:280px;object-fit:cover}
    .ir-gallery .ir-plan img{object-fit:contain;padding:16px;background:#e6e6e6}
    @media(max-width:1050px){.ir-lead,.ir-copy,.ir-grid{grid-template-columns:1fr}.ir-summary{min-height:500px}.ir-map{min-height:520px}}
    @media(max-width:720px){.ir-wrap{width:min(100% - 24px,1440px)}.ir-title{align-items:flex-start;flex-direction:column}.ir-title h1{font-size:42px}.ir-main,.ir-main img{min-height:340px}.ir-summary{min-height:0;padding:26px 20px}.ir-body{padding:46px 0 62px}.ir-copy{gap:35px;padding-bottom:42px}.ir-grid{padding-top:42px}.ir-specs,.ir-gallery{padding:22px 18px}.ir-specs dl,.ir-gallery>div{grid-template-columns:1fr}.ir-specs dl>div:nth-child(odd),.ir-specs dl>div:nth-child(even){padding:14px 0;border-left:0}.ir-map a{position:static;display:inline-block;margin-top:15px}.ir-gallery button,.ir-gallery img{min-height:225px}}
  </style>
<!-- DETAIL_MODERN_V21_START -->
<style is:global>
/* DETAIL_MODERN_V21 */
.ir-copy{display:none!important}
.ir-title div>span{display:none!important}
html:has(.ir-page),body:has(.ir-page){background:#fff!important;color:#111!important}
.ir-page,.ir-page *{color:#111}
.ir-hero,.ir-body{background:#fff!important}
.ir-hero{padding:28px 0 56px!important;border-bottom:0!important}
.ir-title{align-items:center!important;margin-bottom:22px!important}
.ir-title p,.ir-kicker,.ir-summary dt{color:#6b7280!important}
.ir-title h1{font-size:clamp(42px,5.2vw,78px)!important;line-height:.95!important;letter-spacing:-.04em!important;font-weight:800!important}
.ir-title>a{border:1px solid #e5e7eb!important;background:#f5f5f5!important;color:#111!important;border-radius:14px!important;padding:14px 18px!important}
.ir-lead{grid-template-columns:minmax(0,1.65fr) minmax(320px,.7fr)!important;gap:22px!important;min-height:auto!important;background:transparent!important}
.ir-main,.ir-summary,.ir-map,.ir-specs,.ir-gallery{border:1px solid #e5e7eb!important;border-radius:24px!important;overflow:hidden!important;box-shadow:none!important}
.ir-main{min-height:560px!important;background:#f3f4f6!important}
.ir-main img{min-height:560px!important}
.ir-summary{background:#f3f4f6!important;padding:28px 24px!important}
.ir-summary dl>div{padding:18px 0!important;border-bottom:1px solid #e5e7eb!important}
.ir-summary dd{font-size:20px!important;line-height:1.3!important}
.ir-cta{margin-top:18px!important;background:#111!important;color:#fff!important;border-radius:14px!important;min-height:52px!important}
.ir-grid{padding-top:0!important;grid-template-columns:minmax(0,1.1fr) minmax(320px,.9fr)!important;gap:22px!important}
.ir-map,.ir-specs,.ir-gallery{background:#f8f8f8!important}
.ir-map>div{background:#f8f8f8!important;padding:24px!important}
.ir-map h2,.ir-specs h2,.ir-gallery h2{font-size:clamp(24px,2vw,32px)!important;line-height:1.1!important;margin-bottom:14px!important}
.ir-map a{background:#fff!important;border:1px solid #e5e7eb!important;border-radius:12px!important}
.ir-map iframe{min-height:420px!important}
.ir-specs{padding:24px!important}
.ir-specs dl{margin-top:18px!important;border-top:0!important;display:grid!important;grid-template-columns:1fr!important;gap:10px!important}
.ir-specs dl>div{display:grid!important;grid-template-columns:minmax(180px,.9fr) minmax(0,1.1fr)!important;gap:14px!important;padding:14px 16px!important;border:1px solid #e5e7eb!important;border-radius:14px!important;background:#fff!important}
.ir-specs dl>div:nth-child(even),.ir-specs dl>div:nth-child(odd){padding:14px 16px!important;border-left:1px solid #e5e7eb!important}
.ir-specs dt{color:#6b7280!important;font-weight:600!important}
.ir-specs dd{font-weight:700!important}
.ir-gallery{padding:24px!important}
.ir-gallery>div{gap:16px!important}
.ir-gallery button{min-height:260px!important;border-radius:18px!important;background:#f0f0f0!important}
.ir-gallery img{min-height:260px!important}
@media (max-width:1050px){.ir-lead,.ir-grid{grid-template-columns:1fr!important}.ir-main,.ir-main img{min-height:360px!important}}
@media (max-width:720px){.ir-wrap{width:min(100% - 24px,1440px)!important}.ir-hero{padding:22px 0 34px!important}.ir-title h1{font-size:44px!important}.ir-main,.ir-main img{min-height:280px!important}.ir-summary{padding:22px 18px!important}.ir-grid{gap:18px!important}.ir-map iframe{min-height:320px!important}.ir-gallery>div{grid-template-columns:1fr!important}.ir-gallery button,.ir-gallery img{min-height:220px!important}}
/* DETAIL_TELEGRAM_CONTACT_STYLES_START */
.ir-summary-contact{display:grid;place-items:center;width:64px;height:64px;margin:28px auto 0;border-radius:50%;background:#ffc400;color:#111;text-decoration:none;transition:transform .18s ease,filter .18s ease}
.ir-summary-contact:hover{transform:translateY(-2px);filter:brightness(.96)}
.ir-summary-contact:focus-visible{outline:3px solid #111;outline-offset:4px}
.ir-summary-contact svg{width:28px;height:28px;fill:currentColor}
.ir-hero{padding-bottom:0!important}
.ir-body{padding-top:30px!important}
@media(max-width:720px){.ir-summary-contact{width:58px;height:58px;margin-top:22px}.ir-body{padding-top:30px!important}}
/* DETAIL_TELEGRAM_CONTACT_STYLES_END */
</style>
<!-- DETAIL_MODERN_V21_END -->

  <!-- DETAIL_CTRL_MAP_V1_START -->
  <script is:inline>
    (() => {
      const setup = () => {
        const maps = Array.from(document.querySelectorAll("[data-detail-ctrl-map]"));
        if (!maps.length) return;
        let hovered = null;
        let leftCtrlDown = false;
        const sync = () => maps.forEach((node) => {
          const active = node === hovered && leftCtrlDown;
          node.classList.toggle("is-ctrl-active", active);
          const text = node.querySelector(".detail-map-ctrl-hint__text");
          if (text) text.textContent = active ? "Масштабирование включено" : "Удерживайте левый Ctrl и прокручивайте колесо";
        });
        maps.forEach((node) => {
          node.addEventListener("pointerenter", () => { hovered = node; sync(); });
          node.addEventListener("pointerleave", () => { if (hovered === node) hovered = null; sync(); });
        });
        document.addEventListener("keydown", (event) => { if (event.code === "ControlLeft") { leftCtrlDown = true; sync(); } });
        document.addEventListener("keyup", (event) => { if (event.code === "ControlLeft") { leftCtrlDown = false; sync(); } });
        window.addEventListener("blur", () => { leftCtrlDown = false; sync(); });
      };
      if (document.readyState === "loading") document.addEventListener("DOMContentLoaded", setup, { once: true });
      else setup();
    })();
  </script>
  <!-- DETAIL_CTRL_MAP_V1_END -->
</BaseLayout>
