---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/reference-theme.css';
import Header from '../components/Header.astro';
import HomeHero from '../components/HomeHero.astro';
import MarketStats from '../components/MarketStats.astro';
import Warehouses from '../components/Warehouses.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="ArendaSklada.uz — аренда складов от собственника в Ташкенте"
  description="Складские помещения и индустриальные объекты в аренду от собственника в Узбекистане. Карта, фильтры по площади, температуре, типу аренды и готовности."
  canonical="https://arendasklada.uz/"
  image="https://arendasklada.uz/images/hero-warehouse-bg.jpg"
>
  <Header />
  <HomeHero />

  <main>
    <MarketStats />
    <Warehouses />
    <Contact />
  </main>

  <Footer />
</BaseLayout>
