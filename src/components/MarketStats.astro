---
import { getPublishedWarehouses } from "../lib/warehouses";

const warehouses=await getPublishedWarehouses();
const validArea=(value)=>Number.isFinite(value)&&value>0?value:null;
const parseRate=(value)=>{
  const normalized=String(value??"").replaceAll(",",".");
  const numbers=normalized.match(new RegExp("\d+(?:\.\d+)?","g"));
  if(!numbers||!numbers.length)return null;
  const first=Number(numbers[0]);
  if(!Number.isFinite(first))return null;
  const hasRange=normalized.includes("-")||normalized.includes("–")||normalized.includes("—");
  if(hasRange&&numbers.length>1){
    const second=Number(numbers[1]);
    if(Number.isFinite(second))return (first+second)/2;
  }
  return first;
};

const existingVacancy=warehouses.reduce((sum,item)=>{
  const area=validArea(item.data.area);
  return item.data.ready==="Действующий"&&item.data.availableNow===true&&area!==null?sum+area:sum;
},0);

const constructionArea=warehouses.reduce((sum,item)=>{
  const area=validArea(item.data.area);
  return item.data.ready==="Строящийся"&&area!==null?sum+area:sum;
},0);

const weightedRate=(warehouseClass)=>{
  let weightedSum=0;
  let totalArea=0;
  for(const item of warehouses){
    const className=String(item.data.warehouseClass??"").trim().toUpperCase();
    const area=validArea(item.data.area);
    const rate=parseRate(item.data.price);
    if(!className.startsWith(warehouseClass)||area===null||rate===null)continue;
    weightedSum+=area*rate;
    totalArea+=area;
  }
  return totalArea>0?weightedSum/totalArea:null;
};

const rateA=weightedRate("A");
const rateB=weightedRate("B");
const formatArea=(value)=>Math.round(value).toLocaleString("ru-RU");
const formatRate=(value)=>value===null?"—":"$"+value.toLocaleString("ru-RU",{minimumFractionDigits:1,maximumFractionDigits:1});

const stats=[
  {kicker:"Действующие склады",value:formatArea(existingVacancy),unit:"м²",label:"Суммарная вакансия"},
  {kicker:"Строящиеся склады",value:formatArea(constructionArea),unit:"м²",label:"Площадь нового предложения"},
  {kicker:"Класс A",value:formatRate(rateA),unit:rateA===null?"":"/ м² / мес.",label:"Средневзвешенная ставка аренды"},
  {kicker:"Класс B",value:formatRate(rateB),unit:rateB===null?"":"/ м² / мес.",label:"Средневзвешенная ставка аренды"},
];
---

<section class="market-stats" aria-label="Статистика складских объектов">
  <div class="market-stats__grid">
    {stats.map((stat)=><article class="market-stat">
      <span class="market-stat__kicker">{stat.kicker}</span>
      <div class="market-stat__value">
        <strong>{stat.value}</strong>
        {stat.unit&&<span>{stat.unit}</span>}
      </div>
      <p>{stat.label}</p>
    </article>)}
  </div>
</section>
