---
import { readFileSync } from 'node:fs';
import type { WarehouseEntry } from '../lib/warehouses';
import { getWarehouseUrl } from '../lib/warehouses';
import { relativePath } from '../lib/paths';

const { warehouse, index } = Astro.props as { warehouse: WarehouseEntry; index: number };
const currentPath = Astro.url.pathname;
const data = warehouse.data;
const detailUrl = relativePath(getWarehouseUrl(warehouse), currentPath);
const mainImage = relativePath(data.mainImage, currentPath);
const telegramContactIcon = relativePath('/telegram-contact.svg', currentPath);

const contactSource = readFileSync('src/components/Contact.astro', 'utf8');
const telegramHref = contactSource.match(/ARENDASKLADA_MARKER_TELEGRAM[\s\S]*?href="([^"]+)"/)?.[1] ?? '';
const hasTelegram = /^https?:\/\/(?:t\.me|telegram\.me)\//i.test(telegramHref) && !/REPLACE_ME/i.test(telegramHref);

const search = `${data.title} ${data.block} ${data.city} ${data.district} ${data.propertyType} ${data.area} ${data.temperatureMode} ${data.leaseType} ${data.ready} ${data.price}`;
const displayTitle = data.title.replace(/^Логистический центр\s*[—-]\s*/i, '');
const rawPrice = String(data.price ?? '').trim();
const priceNumber = rawPrice.match(/\d+(?:[.,]\d+)?/)?.[0];
const rentRate = rawPrice.toLowerCase() === 'по запросу' || !priceNumber
  ? 'По запросу'
  : `от $ ${priceNumber} за м²`;
const readyText = String(data.ready ?? '').trim().toLowerCase();
const displayReady = readyText.includes('стро') ? 'Строящийся' : 'Действующий';
---

<article
  class="warehouse-card warehouse-card--final"
  id={`object-${data.pageSlug}`}
  data-property-card
  data-title={data.title}
  data-city={data.city}
  data-district={data.district}
  data-type={data.propertyType}
  data-area={data.area}
  data-price={data.price}
  data-availability={data.ready}
  data-temperature={data.temperatureMode}
  data-lease-type={data.leaseType}
  data-order={data.order}
  data-search={search}
  style="position:relative; display:flex; flex-direction:column; width:100%; height:auto; min-height:0; aspect-ratio:2 / 3; overflow:hidden;"
>
  {hasTelegram && (
    <a
      class="warehouse-card-telegram"
      href={telegramHref}
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Открыть Telegram"
      title="Открыть Telegram"
    >
      <img src={telegramContactIcon} alt="" width="34" height="34" />
    </a>
  )}

  <a class="warehouse-card-media" href={detailUrl} aria-label={`Открыть ${data.title}`} style="display:block; flex:0 0 44%; width:100%; height:44%; min-height:0; max-height:44%; overflow:hidden;">
    <img src={mainImage} alt={data.imageAlt} loading={index > 2 ? 'lazy' : 'eager'} style="display:block; width:100%; height:100%; object-fit:cover; object-position:center;" />
  </a>

  <div class="warehouse-card-content" style="display:flex; flex:1 1 56%; flex-direction:column; justify-content:flex-start; width:100%; height:56%; min-height:0; max-height:56%; padding:18px; box-sizing:border-box; overflow:hidden;">
    <h3 style="font-size:22px; line-height:1.05; min-height:0; margin:0 18px 18px; width:calc(100% - 36px); box-sizing:border-box;"><a href={detailUrl}>{displayTitle}</a></h3>

    <dl class="warehouse-card-specs warehouse-card-specs--final" style="flex:0 0 auto; width:100%; margin:0 0 18px; padding-left:18px; padding-right:18px; box-sizing:border-box;">
      <div>
        <dt style="font-size:14px; line-height:1.15; font-weight:700;">Площадь:</dt>
        <dd style="font-size:14px; line-height:1.15; font-weight:400;">{data.area.toLocaleString('ru-RU')} м²</dd>
      </div>
      <div>
        <dt style="font-size:14px; line-height:1.15; font-weight:700;">Ставка аренды:</dt>
        <dd style="font-size:14px; line-height:1.15; font-weight:400;">{rentRate}</dd>
      </div>
      <div>
        <dt style="font-size:14px; line-height:1.15; font-weight:700;">Готовность:</dt>
        <dd style="font-size:14px; line-height:1.15; font-weight:400;">{displayReady}</dd>
      </div>
    </dl>

    <div class="warehouse-card-actions" style="display:block; flex:0 0 auto; width:100%; margin:auto 0 0; padding:0; box-sizing:border-box;">
      <a class="button button-dark" style="display:flex; width:100%; min-height:40px; padding:9px 12px; box-sizing:border-box;" href={detailUrl}>Подробнее</a>
    </div>
  </div>
</article>
