---
import { readFileSync } from 'node:fs';
import type { WarehouseEntry } from '../lib/warehouses';
import { getWarehouseUrl } from '../lib/warehouses';
import { relativePath } from '../lib/paths';

const { warehouse, index } = Astro.props as { warehouse: WarehouseEntry; index: number };

const currentPath = Astro.url.pathname;
const data = warehouse.data;
const cleanLeaseType = data.leaseType.replace(/["“”]/g, '').trim();
const leaseTypeLines = /\s+аренда$/i.test(cleanLeaseType) ? [cleanLeaseType.replace(/\s+аренда$/i, ''), 'аренда'] : [cleanLeaseType];

const detailUrl = relativePath(getWarehouseUrl(warehouse), currentPath);
const mainImage = relativePath(data.mainImage, currentPath);
const contactSource = readFileSync('src/components/Contact.astro', 'utf8');
const telegramHref = contactSource.match(/ARENDASKLADA_MARKER_TELEGRAM[\s\S]*?href="([^"]+)"/)?.[1] ?? '';
const hasTelegram = /^https?:\/\/(?:t\.me|telegram\.me)\//i.test(telegramHref) && !/REPLACE_ME/i.test(telegramHref);

const search = `${data.title} ${data.block} ${data.city} ${data.district} ${data.propertyType} ${data.area} ${data.temperatureMode} ${data.leaseType} ${data.ready}`;

const displayTitle = data.title.replace(/^Логистический центр\s*[—-]\s*/i, '');
const rawPrice = data.price.trim();
const priceNumber = rawPrice.match(/\d+(?:[.,]\d+)?/)?.[0];
const rentRate = rawPrice.toLowerCase() === 'по запросу' || !priceNumber
  ? 'По запросу'
  : `от $ ${priceNumber} за м²`;
const displayReady = data.ready.trim().toLowerCase() === 'действующий'
  ? 'Действующий' : data.ready;
const displayLeaseType = data.leaseType
  .replace(/["“”]/g, '')
  .trim()
  .replace(/^Сухая аренда$/i, 'Сухая\nаренда')
  .replace(/^Стеллажная аренда$/i, 'Стеллажная\nаренда');
---

<article
  class="warehouse-card"
  id={`object-${data.pageSlug}`}
  data-property-card
  data-title={data.title}
  data-city={data.city}
  data-district={data.district}
  data-type={data.propertyType}
  data-area={data.area}
  data-availability={data.ready}
  data-temperature={data.temperatureMode}
  data-lease-type={data.leaseType}
  data-order={data.order}
  data-search={search}
>
  {hasTelegram && (
    <a
      class="warehouse-card-telegram"
      href={telegramHref}
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Написать в Telegram"
      title="Написать в Telegram"
    >
      <svg viewBox="0 0 24 24" aria-hidden="true">
        <path d="M6.6 10.4c2.1 4.1 5.4 6.3 6.2 6.7.4.2.8.1 1.2-.1l1.9-1.2c.4-.3.9-.2 1.2 0l2.7 1.8c.5.4 1.2.2 1.4-.4l.8-2c.2-.5.1-1-.3-1.3l-2.8-2c-.3-.3-.4-.7-.2-1.1l.9-1.5c.2-.3.3-.7.1-1.1-.7-1.4-2.4-3.9-6.4-5.9-.4-.2-.8-.2-1.2 0l-1.6.9c-.4.2-.6.7-.3 1.1l1.7 2.8c.2.4.2.8 0 1.1l-.9 1.4c-.3.4-.7.5-1.1.2L7.2 8c-.4-.3-.9-.2-1.2.2L4.4 10c-.3.3-.3.8-.1 1.2z" />
      </svg>
    </a>
  )}

  <a class="warehouse-card-media" href={detailUrl} aria-label={`Открыть ${data.title}`}>
    <img src={mainImage} alt={data.imageAlt} loading={index > 2 ? 'lazy' : 'eager'} />
  </a>

  <div class="warehouse-card-content">
    <h3>
      <a href={detailUrl}>{displayTitle}</a>
    </h3>

    <dl class="warehouse-card-specs">
      <div>
        <dt>Площадь</dt>
        <dd>{data.area.toLocaleString('ru-RU')} м²</dd>
      </div>

      <div>
        <dt>Тип аренды</dt>
        <dd class="warehouse-card-lease-value">{leaseTypeLines.map((line) => <span>{line}</span>)}</dd>
      </div>

      <div class="warehouse-card-rate">
        <dt>Ставка аренды</dt>
        <dd>{rentRate}</dd>
        <small>не включая НДС и эксплуатацию</small>
      </div>

      <div>
        <dt>Готовность</dt>
        <dd class="warehouse-card-ready-value">{displayReady}</dd>
      </div>
    </dl>

    <div class="warehouse-card-actions">
      <a class="button button-dark" href={detailUrl}>Подробнее</a>
    </div>
  </div>
</article>
