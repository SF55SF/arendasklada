---
import { getPublishedWarehouses } from '../lib/warehouses';
import WarehousesTable from './WarehousesTable.astro';

const warehouses = await getPublishedWarehouses();
---

<WarehousesTable warehouses={warehouses} />

<style is:global>
  @media (min-width: 821px) {
    .catalog-split {
      grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    }

    .catalog-map-panel,
    .catalog-results-panel {
      min-width: 0;
      width: 100%;
    }
  }
</style>