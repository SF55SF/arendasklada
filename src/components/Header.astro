---
import { navItems } from '../data/navigation';
import { homePath, resolveNavHref } from '../lib/paths';

const currentPath = Astro.url.pathname;
const logoHref = homePath(currentPath);
---

<header class="site-header">
  <a class="logo" href={logoHref} aria-label="На главную страницу arendasklada.uz">
    <span class="logo-mark">AS</span>
    <span>ArendaSklada.uz</span>
  </a>

  <nav id="main-menu" class="main-nav" aria-label="Основная навигация">
    {navItems.map((item) => (
      <a href={resolveNavHref(item.href, currentPath)}>
        {item.label}
      </a>
    ))}
  </nav>

  <div class="header-contacts">
    <!-- ARENDASKLADA_MARKER_CONTACT_PHONE: replace phone when final contact is ready. -->
    <a href="tel:+998000000000">+998 00 000 00 00</a>
    <!-- ARENDASKLADA_MARKER_CONTACT_EMAIL: replace email when mailbox is connected. -->
    <a href="mailto:info@arendasklada.uz">info@arendasklada.uz</a>
  </div>

  <div class="mobile-header-actions">
    <button
      class="mobile-contact-button"
      type="button"
      aria-label="Показать контакты"
      aria-expanded="false"
      aria-controls="mobile-contact-popover"
    >
      <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
        <path d="M6.7 3.8c.4-.4 1-.5 1.5-.2l2.1 1.2c.5.3.7.9.5 1.4l-.9 2c-.2.5-.1 1 .2 1.4l1.8 1.9 1.9 1.8c.4.3.9.4 1.4.2l2-.9c.5-.2 1.1 0 1.4.5l1.2 2.1c.3.5.2 1.1-.2 1.5l-1 1c-.8.8-2 1.1-3.1.8-2.6-.7-5.1-2.2-7.4-4.5S4.3 9.2 3.6 6.6c-.3-1.1 0-2.3.8-3.1l1-1Z" />
      </svg>
    </button>

    <button
      class="menu-button"
      type="button"
      aria-label="Открыть меню"
      aria-expanded="false"
      aria-controls="main-menu"
    >
      <span class="menu-button__line"></span>
      <span class="menu-button__line"></span>
      <span class="menu-button__text">Меню</span>
    </button>
  </div>

  <div id="mobile-contact-popover" class="mobile-contact-popover" aria-label="Быстрые контакты">
    <strong>Связаться с нами</strong>
    <!-- ARENDASKLADA_MARKER_CONTACT_PHONE: replace phone when final contact is ready. -->
    <a href="tel:+998000000000">+998 00 000 00 00</a>
    <!-- ARENDASKLADA_MARKER_CONTACT_EMAIL: replace email when mailbox is connected. -->
    <a href="mailto:info@arendasklada.uz">info@arendasklada.uz</a>
    <!-- ARENDASKLADA_MARKER_TELEGRAM: replace Telegram link. -->
    <a href="https://t.me/ARENDASKLADA_REPLACE_ME" target="_blank" rel="noopener noreferrer">Telegram</a>
  </div>
</header>
