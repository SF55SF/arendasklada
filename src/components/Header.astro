---
import { navItems } from '../data/navigation';
import { homePath, relativePath, resolveNavHref } from '../lib/paths';

const currentPath = Astro.url.pathname;
const logoHref = homePath(currentPath);
const logoMark = relativePath("/logo-mark.svg", currentPath);
const telegramContactIcon = relativePath("/telegram-contact.svg", currentPath);
---

<header class="site-header">
  <a class="logo" href={logoHref} aria-label="На главную страницу arendasklada.uz">
    <img class="logo-mark" src={logoMark} alt="" width="42" height="42" />
    <span>ArendaSklada.uz</span>
  </a>

  <nav id="main-menu" class="main-nav" aria-label="Основная навигация">
    {navItems.map((item) => (
      <a href={resolveNavHref(item.href, currentPath)}>
        {item.label}
      </a>
    ))}
  </nav>

  <div class="header-contacts">
    <!-- ARENDASKLADA_MARKER_CONTACT_PHONE: replace phone when final contact is ready. -->
    <a href="tel:+998505906059">+998 50 590 60 59</a>
    <!-- ARENDASKLADA_MARKER_CONTACT_EMAIL: replace email when mailbox is connected. -->
    <a href="mailto:sanjar.saimatov@cmwp.uz">sanjar.saimatov@cmwp.uz</a>
  </div>

  <div class="mobile-header-actions">
    <!-- ARENDASKLADA_TELEGRAM_HEADER_START -->
    <a
      class="mobile-contact-button"
      href="https://t.me/sanjar_saymatov_cmwp"
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Написать в Telegram"
    >
      <img src={telegramContactIcon} alt="" width="34" height="34" />
    </a>
    <!-- ARENDASKLADA_TELEGRAM_HEADER_END -->

    <button
      class="menu-button"
      type="button"
      aria-label="Открыть меню"
      aria-expanded="false"
      aria-controls="main-menu"
    >
      <span class="menu-button__line"></span>
      <span class="menu-button__line"></span>
      <span class="menu-button__text">Меню</span>
    </button>
  </div>

</header>
